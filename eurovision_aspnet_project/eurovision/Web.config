<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<runtime>
		<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
			<dependentAssembly>
				<assemblyIdentity name="Microsoft.Web.Infrastructure"
								  publicKeyToken="31bf3856ad364e35"
								  culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-2.0.0.0"
								 newVersion="2.0.0.0" />
			</dependentAssembly>
		</assemblyBinding>
	</runtime>
	<connectionStrings>
		<!-- 
      כאן מגדירים את החיבור ל-SQL Server
      אם את משתמשת ב-SQLEXPRESS, יכול להיות שתצטרכי לשנות את שם השרת
    -->
		<add name="MyConnectionString"
			 connectionString="Password=123456;Persist Security Info=True;User ID=sa;Initial Catalog=EurovisionDB;Data Source=.\sqlexpress"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>

	<system.web>
		<compilation debug="true" targetFramework="4.8" />
		<httpRuntime targetFramework="4.8" />
	</system.web>
</configuration>